---
import { getLangFromUrl, useTranslations, getAltLangHref, type Lang } from '../i18n/ui';

interface Props {
  /** URL alternativa para el conmutador de idioma (p. ej. la traducción de un post) */
  altLangHref?: string;
}

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const { altLangHref } = Astro.props;

const prefix = lang === 'es' ? '' : '/en';
const links = [
  { href: `${prefix}/`, label: t('nav.home') },
  { href: `${prefix}/blog/`, label: t('nav.blog') },
  { href: lang === 'es' ? '/proyectos/' : '/en/projects/', label: t('nav.projects') },
  { href: lang === 'es' ? '/sobre-mi/' : '/en/about/', label: t('nav.about') },
];

const switchHref = altLangHref ?? getAltLangHref(Astro.url.pathname, lang);
const otherLang: Lang = lang === 'es' ? 'en' : 'es';

const normalize = (p: string) => (p.endsWith('/') ? p : p + '/');
const current = normalize(Astro.url.pathname);
const isActive = (href: string) =>
  href === `${prefix}/` ? current === href : current.startsWith(href);
---

<header class="nav-wrap">
  <nav-menu class="container nav" aria-label="principal">
    <a href={`${prefix}/`} class="logo" aria-label={t('site.title')}>
      oscar<span class="logo-dot">.</span>
    </a>

    <div class="nav-actions">
      <a
        href={switchHref}
        class="nav-link lang-switch lang-switch-quick"
        aria-label={otherLang === 'en' ? 'Switch to English' : 'Cambiar a español'}
      >
        {otherLang.toUpperCase()}
      </a>

      <button
        type="button"
        class="nav-toggle"
        aria-label={lang === 'es' ? 'Abrir menú' : 'Open menu'}
        aria-expanded="false"
        aria-controls="nav-links"
      >
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
        <span class="nav-toggle-bar"></span>
      </button>
    </div>

    <div class="nav-links" id="nav-links">
      {
        links.map((link) => (
          <a href={link.href} class:list={['nav-link', { active: isActive(link.href) }]}>
            {link.label}
          </a>
        ))
      }
      <a
        href={switchHref}
        class="nav-link lang-switch lang-switch-menu"
        aria-label={otherLang === 'en' ? 'Switch to English' : 'Cambiar a español'}
      >
        {otherLang.toUpperCase()}
      </a>
    </div>
  </nav-menu>
</header>

<script>
  class NavMenu extends HTMLElement {
    connectedCallback() {
      const btn = this.querySelector<HTMLButtonElement>('.nav-toggle');
      const links = this.querySelector<HTMLElement>('.nav-links');
      if (!btn || !links) return;

      const close = () => {
        this.classList.remove('is-open');
        btn.setAttribute('aria-expanded', 'false');
      };
      const toggle = () => {
        const open = this.classList.toggle('is-open');
        btn.setAttribute('aria-expanded', String(open));
      };

      btn.addEventListener('click', toggle);
      // cerrar al elegir un enlace o pulsar Escape
      links.addEventListener('click', (e) => {
        if ((e.target as HTMLElement).closest('a')) close();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close();
      });
    }
  }

  if (!customElements.get('nav-menu')) {
    customElements.define('nav-menu', NavMenu);
  }
</script>

<style>
  .nav-wrap {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--bg);
    border-bottom: 1px solid var(--hairline);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 4.2rem;
  }

  .nav-actions {
    display: flex;
    align-items: center;
    gap: 0.9rem;
  }

  /* en escritorio el conmutador vive dentro del menú, no junto al logo */
  .lang-switch-quick {
    display: none;
  }

  /* botón hamburguesa: oculto en escritorio */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 42px;
    height: 42px;
    margin-right: -9px;
    padding: 0;
    background: none;
    border: none;
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
  }

  .nav-toggle-bar {
    display: block;
    width: 22px;
    height: 2px;
    margin: 0 auto;
    background: var(--text);
    border-radius: 2px;
    transition: transform 0.25s ease, opacity 0.2s ease;
  }

  .logo {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 1.2rem;
    letter-spacing: -0.01em;
    color: var(--text);
  }

  .logo-dot {
    color: var(--text-faint);
    transition: color 0.2s ease;
  }

  .logo:hover .logo-dot {
    color: var(--text);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 1.7rem;
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s ease;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text);
  }

  .lang-switch {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.08em;
  }

  @media (max-width: 600px) {
    .nav {
      height: 3.7rem;
    }

    .nav-toggle {
      display: flex;
    }

    /* el conmutador rápido aparece junto a la hamburguesa */
    .lang-switch-quick {
      display: inline-flex;
      align-items: center;
      padding: 0.35rem 0.6rem;
      border: 1px solid var(--hairline);
      border-radius: 7px;
      color: var(--text);
    }

    /* y desaparece de dentro del menú para no duplicarlo */
    .lang-switch-menu {
      display: none;
    }

    /* el panel de enlaces se despliega bajo el header */
    .nav-links {
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      flex-direction: column;
      align-items: stretch;
      gap: 0;
      background: var(--bg);
      border-bottom: 1px solid var(--hairline);
      box-shadow: 0 12px 24px rgba(0, 0, 0, 0.06);
      padding: 0.4rem 0;
      /* oculto por defecto, sin animar el layout */
      opacity: 0;
      transform: translateY(-8px);
      pointer-events: none;
      transition: opacity 0.2s ease, transform 0.2s ease;
    }

    :global(nav-menu.is-open) .nav-links {
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    .nav-link {
      padding: 0.85rem clamp(1.15rem, 5vw, 1.5rem);
      font-size: 1rem;
    }

    .nav-link.active {
      box-shadow: inset 3px 0 0 var(--ink);
    }

    /* animación de la X al abrir */
    :global(nav-menu.is-open) .nav-toggle-bar:nth-child(1) {
      transform: translateY(7px) rotate(45deg);
    }

    :global(nav-menu.is-open) .nav-toggle-bar:nth-child(2) {
      opacity: 0;
    }

    :global(nav-menu.is-open) .nav-toggle-bar:nth-child(3) {
      transform: translateY(-7px) rotate(-45deg);
    }
  }
</style>
