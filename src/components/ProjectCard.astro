---
import type { ProjectEntry } from '../data/projects';
import { projectHref } from '../data/projects';
import type { Lang } from '../i18n/ui';

interface Props {
  project: ProjectEntry;
  lang: Lang;
}

const { project, lang } = Astro.props;
const { title, description, type, tech } = project.data;
const isFun = type === 'fun';
const badgeLabel = isFun
  ? (lang === 'es' ? 'JUEGO' : 'FUN')
  : (lang === 'es' ? 'TRABAJO' : 'WORK');
const href = projectHref(project);
---

<a href={href} class:list={['card', 'project-card', 'reveal', isFun && 'is-fun']}>
  <div class="project-head">
    <h3>{title}</h3>
    <span class="badge">{badgeLabel}</span>
  </div>
  <p>{description}</p>
  <div class="project-foot">
    <span class="tech">
      {tech.map((t, i) => (
        <>
          <span>{t}</span>
          {i < tech.length - 1 && <span class="dot">·</span>}
        </>
      ))}
    </span>
    <span class="arrow" aria-hidden="true">→</span>
  </div>
</a>

<style>
  .project-card {
    display: flex;
    flex-direction: column;
    gap: 0;
    padding: 28px;
    border-radius: 18px;
  }

  .project-head {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 16px;
    margin-bottom: 16px;
  }

  h3 {
    margin: 0;
    font-size: 1.35rem;
    font-weight: 600;
    letter-spacing: -0.015em;
    line-height: 1.2;
  }

  .badge {
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: 0.62rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 5px 9px;
    border-radius: 6px;
    white-space: nowrap;
    border: 1px solid var(--hairline);
    color: var(--text-muted);
  }

  .is-fun .badge {
    color: #B0673F;
    border-color: #E8C9B8;
  }

  p {
    margin: 0;
    color: var(--text-muted);
    font-size: 1rem;
    line-height: 1.55;
    flex-grow: 1;
  }

  .project-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin-top: 20px;
    padding-top: 20px;
    border-top: 1px solid #F0EEE9;
  }

  .tech {
    display: flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-faint);
  }

  .dot {
    color: #D6D2C9;
  }

  .arrow {
    color: var(--text-faint);
    font-size: 1rem;
    flex-shrink: 0;
    transition: transform 0.25s ease, color 0.2s ease;
  }

  .project-card:hover .arrow {
    transform: translateX(4px);
    color: var(--text);
  }
</style>
